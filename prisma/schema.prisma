// REPAIR REQUEST FRONT_DESK MODELS
model RepairRequest {
  id             String               @id @default(cuid())
  requestNumber  String               @unique
  requestStatus  RepairRequestStatus  @default(PENDING_FRONT_DESK)
  handoverStatus RepairHandoverStatus @default(PENDING)
  orgId          String?
  org            Organization?        @relation(fields: [orgId], references: [id], onDelete: SetNull)

  // Customer info
  customerName           String
  phone                  String
  email                  String?
  preferredContactMethod ContactMethod @default(WHATSAPP)

  // Device info
  deviceType   DeviceType
  brand        String
  model        String?
  serialNumber String?

  // Problem description
  problemDescription String

  // Handover method specific fields
  handoverMethod       HandoverMethod
  preferredDropoffDate String?
  preferredDropoffTime String?
  dropoffNotes         String?

  deliveryPersonName        String?
  deliveryPersonPhone       String?
  deliveryCompany           String?
  dispatchDate              String?
  expectedArrivalTime       String?
  deliveryTrackingReference String?
  deliveryFeeResponsibility String?
  deliveryNotes             String?

  pickupAddress          String?
  pickupLandmark         String?
  preferredPickupDate    String?
  preferredPickupTime    String?
  alternateContactPerson String?
  alternateContactPhone  String?
  pickupNotes            String?

  // Linked job (set when converted to a job)
  linkedJobId String?

  // Anti-spam
  submissionIp String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outboundMessages OutboundMessage[]

  @@index([requestStatus, createdAt])
  @@index([phone])
}

// Allocates human-friendly repair request numbers safely under concurrency.
model RepairRequestSequence {
  id        String        @id @default(cuid())
  orgId     String?
  org       Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  year      Int
  value     Int           @default(0)
  updatedAt DateTime      @updatedAt

  @@unique([orgId, year])
}

// Allocates human-friendly ticket numbers safely under concurrency.
model TicketSequence {
  id        String        @id @default(cuid())
  orgId     String        // non-nullable; use "_public" for un-org-scoped tickets
  org       Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  year      Int
  value     Int           @default(0)
  updatedAt DateTime      @updatedAt

  @@unique([orgId, year])
  @@index([orgId])
}

enum RepairRequestStatus {
  // Legacy: kept for existing production rows.
  PENDING_INTAKE
  PENDING_FRONT_DESK
  APPROVED
  REJECTED
  CONVERTED_TO_JOB
}

enum RepairHandoverStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ContactMethod {
  WHATSAPP
  PHONE
  EMAIL
  SMS
}

enum HandoverMethod {
  SELF_DROPOFF
  SEND_WITH_DELIVERY_PERSON
  REQUEST_PICKUP
}

