// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ── Simplified ICT Ticketing ────────────────────────────────────────────────

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  WAITING_FOR_APPROVAL
  WAITING_FOR_PAYMENT
  RESOLVED
  CLOSED
  CANCELLED
}

enum SLACycle {
  MONTHLY
  ANNUAL
}

enum ClientSubscriptionStatus {
  ACTIVE
  PENDING
  EXPIRED
  CANCELLED
}

enum ClientSubscriptionReminderType {
  TWO_MONTHS
  ONE_MONTH
  TWO_WEEKS
}

enum ClientType {
  INDIVIDUAL
  COMPANY
  SCHOOL
  NGO
  GOVERNMENT
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketCategory {
  HARDWARE
  SOFTWARE
  NETWORK
  INTERNET
  EMAIL
  PRINTER
  OTHER
}

model Ticket {
  id        String          @id @default(cuid())
  ticketNumber String         @unique
  status    TicketStatus    @default(OPEN)
  priority  TicketPriority  @default(MEDIUM)
  category  TicketCategory  @default(OTHER)
  orgId     String?
  org       Organization?   @relation(fields: [orgId], references: [id], onDelete: SetNull)

  // Reporter (may not be a registered user)
  reporterName  String
  reporterPhone String
  reporterEmail String?
  reporterCompany String?

  // Issue
  subject       String
  description   String
  deviceInfo    String?    // e.g., "HP EliteBook 840 G8" or "Office Printer"

  // Client link
  clientId      String?
  client        Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // SLA
  isSLACovered  Boolean    @default(false)

  // Financial
  estimatedCost Float?

  // Linked documents
  quotationId   String?    @unique
  quotation     Quotation? @relation("TicketQuotation", fields: [quotationId], references: [id], onDelete: SetNull)
  invoiceId     String?    @unique
  invoice       Invoice?   @relation("TicketInvoice", fields: [invoiceId], references: [id], onDelete: SetNull)
  receipt       Receipt?   @relation("TicketReceipt")

  // Internal
  assignedToId  String?
  assignedTo    User?      @relation("TicketAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  notes         String?
  resolution    String?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  resolvedAt    DateTime?
  closedAt      DateTime?

  @@index([orgId, status, createdAt])
  @@index([orgId, priority, createdAt])
  @@index([assignedToId, status])
  @@index([clientId])
}

// ── MULTI-TENANCY ────────────────────────────────────────────────────────────

enum OrgPlan {
  STARTER
  STANDARD
  GROWTH
  PREMIUM
  ENTERPRISE
}

enum OrgBillingStatus {
  TRIALING // free trial, no payment yet
  ACTIVE // paid and current
  PAST_DUE // payment failed, grace period
  CANCELLED // subscription cancelled, reverts to STARTER at period end
}

model Organization {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  plan     OrgPlan @default(STARTER)
  isActive Boolean @default(true)

  // Flutterwave subscription tracking
  billingStatus     OrgBillingStatus @default(TRIALING)
  flwCustomerId     String? // Flutterwave customer ID
  flwSubscriptionId String? // active FLW subscription ID
  flwPlanId         String? // FLW payment plan ID in use
  trialEndsAt       DateTime? // null = no trial
  planRenewsAt      DateTime? // next renewal date
  planCancelledAt   DateTime? // set when cancelled

  // AI model override (e.g. "claude-haiku-4-5-20251001"). Null = platform default.
  aiModel String?

  // Multi-currency
  baseCurrency        String @default("UGX")
  supportedCurrencies String @default("UGX") // comma-separated ISO currency codes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                  User[]
  clients                Client[]
  clientSubscriptions    ClientSubscription[]
  devices                Device[]
  jobs                   Job[]
  parts                  Part[]
  repairRequests         RepairRequest[]
  repairRequestSequences RepairRequestSequence[]
  ticketSequences        TicketSequence[]
  brandingSettings       DocumentBrandingSettings?
  commTemplates          CommunicationTemplate[]
  commPolicies           CommunicationPolicy[]
  notifications          Notification[]
  outboundMessages       OutboundMessage[]
  inboundMessages        InboundMessage[]
  invoices               Invoice[]
  payments               Payment[]
  refunds                Refund[]
  creditNotes            CreditNote[]
  sales                  Sale[]
  deliveryNotes          DeliveryNote[]
  auditLogs              AuditLog[]
  invites                UserInvite[]
  branches               Branch[]
  suppliers              Supplier[]
  purchaseRequests       PurchaseRequest[]
  purchaseOrders         PurchaseOrder[]
  stockTransfers         StockTransfer[]
  goodsReceivedNotes     GoodsReceived[]
  supplierBills          SupplierBill[]
  supplierPayments       SupplierPayment[]
  stockCounts            StockCount[]
  userGroups             UserGroup[]
  complaints             Complaint[]
  salesTargets           SalesTarget[]
  moduleGrants           OrgModuleGrant[]
  leads                  Lead[]
  tickets                Ticket[]
  quotations             Quotation[]
  posSessions            PosSession[]
  fieldVisits            FieldVisit[]
  taxRates               TaxRate[]
  expenses               Expense[]
  recurringInvoices      RecurringInvoice[]
  chartOfAccounts        ChartOfAccount[]
  journalEntries         JournalEntry[]
  bankAccounts           BankAccount[]
  bankTransactions       BankTransaction[]
  campaigns              Campaign[]

  @@index([slug])
  @@index([isActive])
}

enum OrgModule {
  JOBS
  SUBSCRIPTIONS
  INVENTORY
  POS
  PURCHASE_ORDERS
  INVOICING
  COMPLAINTS
  REPORTS
  SALES
  FIELD
  TARGETS
}

model OrgModuleGrant {
  orgId  String
  module OrgModule
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, module])
  @@index([orgId])
}

model UserInvite {
  id          String       @id @default(cuid())
  token       String       @unique @default(cuid())
  email       String
  role        Role         @default(OPS)
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedById String
  invitedBy   User         @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime     @default(now())

  @@index([token])
  @@index([orgId])
  @@index([email, orgId])
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  phone         String?
  emailVerified Boolean       @default(false)
  image         String?
  role          Role          @default(OPS)
  isActive      Boolean       @default(true)
  accessMode    UserAccessMode @default(FULL)
  orgId         String?
  org           Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  branchId      String?
  branch        Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  departmentId  String?
  department    Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  techType      TechType?
  employeeId    String?
  specializations String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sessions                Session[]
  accounts                Account[]
  permissionGrants        UserPermission[]
  jobsCreated             Job[]                    @relation("CreatedBy")
  jobsAssigned            Job[]                    @relation("AssignedTo")
  payoutsMarked           Job[]                    @relation("PayoutMarkedBy")
  clientPaymentsMarked    Job[]                    @relation("ClientPaymentMarkedBy")
  auditLogs               AuditLog[]
  clientNotes             ClientNote[]
  notifications           Notification[]
  notificationPreferences NotificationPreferences?
  partReservations        PartReservation[]        @relation("PartReservedBy")
  deliveryNotesCreated    DeliveryNote[]           @relation("DeliveryNoteCreatedBy")
  stockTransactions       PartStockTransaction[]   @relation("StockTxnBy")
  paymentsCreated         Payment[]                @relation("PaymentCreatedBy")
  technicianPayoutsRecorded TechnicianPayout[]      @relation("TechnicianPayoutRecordedBy")
  refundsCreated          Refund[]
  creditNotesCreated      CreditNote[]             @relation("CreditNoteCreatedBy")
  creditNotesReceivedBack CreditNote[]             @relation("CreditNoteReceivedBackBy")
  salesCreated            Sale[]                   @relation("SaleCreatedBy")
  accessAuditEntries      UserAccessAudit[]        @relation("AccessAuditTarget")
  accessAuditChanges      UserAccessAudit[]        @relation("AccessAuditActor")
  invitesSent             UserInvite[]             @relation("InvitedBy")
  groupMemberships        UserGroupMember[]
  complaintsAssigned      Complaint[]      @relation("ComplaintAssignee")
  salesTargets            SalesTarget[]    @relation("SalesTargets")
  targetsSet              SalesTarget[]    @relation("TargetSetBy")
  posSessionsOperated     PosSession[]     @relation("PosSessionOperator")
  leadsCreated            Lead[]           @relation("LeadCreatedBy")
  leadsAssigned           Lead[]           @relation("LeadAssignedTo")
  leadActivities          LeadActivity[]   @relation("LeadActivityBy")
  quotationsCreated       Quotation[]      @relation("QuotationCreatedBy")
  quotationsApproved      Quotation[]      @relation("QuotationApprovedBy")
  fieldVisitsAssigned     FieldVisit[]     @relation("FieldVisitAssignedTo")
  fieldVisitsScheduled    FieldVisit[]     @relation("FieldVisitScheduledBy")
  stockTransfersCreated   StockTransfer[]  @relation("StockTransferCreatedBy")
  stockTransfersApproved  StockTransfer[]  @relation("StockTransferApprovedBy")
  stockTransfersDispatched StockTransfer[] @relation("StockTransferDispatchedBy")
  stockTransfersReceived  StockTransfer[]  @relation("StockTransferReceivedBy")
  goodsReceivedCreated    GoodsReceived[]  @relation("GoodsReceivedCreatedBy")
  supplierBillsCreated    SupplierBill[]   @relation("SupplierBillCreatedBy")
  supplierPaymentsCreated SupplierPayment[] @relation("SupplierPaymentCreatedBy")
  purchaseRequestsCreated PurchaseRequest[] @relation("PurchaseRequestCreatedBy")
  purchaseRequestsReviewed PurchaseRequest[] @relation("PurchaseRequestReviewedBy")
  stockCountsCreated       StockCount[]        @relation("StockCountCreatedBy")
  stockCountsApproved      StockCount[]        @relation("StockCountApprovedBy")
  expensesCreated          Expense[]           @relation("ExpenseCreatedBy")
  recurringInvoicesCreated RecurringInvoice[]  @relation("RecurringInvoiceCreatedBy")
  journalEntriesCreated    JournalEntry[]      @relation("JournalEntryCreatedBy")
  campaignsCreated         Campaign[]          @relation("CampaignCreatedBy")
  ticketsAssigned          Ticket[]            @relation("TicketAssignedTo")

  @@index([orgId])
  @@index([branchId])
  @@index([departmentId])
}

model UserPermission {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission String
  createdAt  DateTime @default(now())

  @@unique([userId, permission])
  @@index([permission])
}

model UserAccessAudit {
  id           String   @id @default(cuid())
  targetUserId String
  targetUser   User     @relation("AccessAuditTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  actorUserId  String
  actorUser    User     @relation("AccessAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  action       String
  detail       String?
  createdAt    DateTime @default(now())

  @@index([targetUserId, createdAt])
  @@index([actorUserId, createdAt])
}

model UserGroup {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  members     UserGroupMember[]
  permissions UserGroupPermission[]

  @@unique([orgId, name])
  @@index([orgId, createdAt])
}

model UserGroupMember {
  id        String    @id @default(cuid())
  groupId   String
  group     UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

model UserGroupPermission {
  id         String    @id @default(cuid())
  groupId    String
  group      UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  permission String
  createdAt  DateTime  @default(now())

  @@unique([groupId, permission])
  @@index([permission])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum Role {
  ADMIN
  MANAGER
  TECH_MANAGER
  FINANCE
  SALES
  SALES_MANAGER
  SALES_CORPORATE
  SALES_RETAIL
  SALES_POS
  TECH_FIELD
  OPS
  TECHNICIAN_INTERNAL
  TECHNICIAN_EXTERNAL
  FRONT_DESK
  // Legacy: kept for existing production rows.
  // The app normalizes this to FRONT_DESK at runtime.
  INTAKE
}

enum UserAccessMode {
  FULL
  READ_ONLY
}

enum TechType {
  INTERNAL
  EXTERNAL_PERMANENT
  EXTERNAL_ONE_TIME
  FIELD
}

enum JobStatus {
  RECEIVED
  DIAGNOSING
  REFERRED
  PENDING_EXTERNAL_ASSIGNMENT
  ASSIGNED_ONE_TIME_EXTERNAL
  IN_EXTERNAL_REPAIR
  WAITING_FOR_PARTS
  RETURNED_FROM_EXTERNAL
  AWAITING_APPROVAL
  IN_REPAIR
  READY_FOR_PICKUP
  DELIVERED
  COMPLETED
  CLOSED
}

enum RecommendationOption {
  PROCEED_REPAIR
  REPLACE_DEVICE
  RETURN_UNREPAIRED
}

enum CommunicationStatus {
  NONE
  AWAITING_RESPONSE
  APPROVED
  DECLINED
}

enum RepairPath {
  IN_HOUSE
  EXTERNAL
}

enum ServiceType {
  HARDWARE
  SOFTWARE
  BOTH
}

enum SoftwareInstallerSource {
  CLIENT_PROVIDED_INSTALLER
  CLIENT_ACCOUNT_LOGIN
  COMPANY_LICENSE
  OPEN_SOURCE
  OTHER
}

enum DeliveryMethod {
  PICKUP
  DELIVERY
  COURIER
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
}

enum InvoiceType {
  REPAIR
  SERVICE
  MERCHANDISE
  CONTRACT
  OTHER
}

enum ExpenseCategory {
  RENT
  UTILITIES
  SALARIES
  SUPPLIES
  MARKETING
  TRAVEL
  EQUIPMENT
  MAINTENANCE
  TAXES
  OTHER
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
  CARD
  OTHER
}

enum SaleBillingMode {
  CASH
  INVOICE
}

enum SaleStatus {
  OPEN
  PAID
  VOID
}

enum DeviceType {
  PHONE_ANDROID
  PHONE_IPHONE
  TABLET
  WINDOWS_PC
  MAC
  OTHER
}

enum TimelineConfidence {
  FIRM
  ESTIMATED
  PARTS_DEPENDENT
}

enum WorkflowReason {
  NONE
  PARTS_PENDING
  SPECIALIST_ESCALATION
  CLIENT_DECLINED
  UNREPAIRABLE
  CUSTOMER_CANCELLED
  OTHER
}

enum PartReservationStatus {
  RESERVED
  CONSUMED
  RELEASED
}

enum StockTransactionType {
  IN
  OUT
  ADJUST
}

enum StockTransferStatus {
  REQUESTED
  APPROVED
  DISPATCHED
  RECEIVED
  CANCELLED
}

model Client {
  id           String        @id @default(cuid())
  fullName       String
  phone          String
  email          String?
  organization   String?
  address        String?
  notes          String?

  // SLA
  clientType     ClientType    @default(INDIVIDUAL)
  isSLACovered   Boolean       @default(false)
  slaStartDate   DateTime?
  slaEndDate     DateTime?
  slaBillingCycle SLACycle?
  slaAmountPaid  Float?
  slaStatus      ClientSubscriptionStatus?

  orgId          String?
  org            Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  jobs               Job[]
  devices            Device[]
  notesEntries       ClientNote[]
  inboundMessages    InboundMessage[]
  sales              Sale[]
  leads              Lead[]
  quotations         Quotation[]
  invoices           Invoice[]
  recurringInvoices  RecurringInvoice[]
  campaignContacts   CampaignContact[]
  tickets            Ticket[]
  subscriptions      ClientSubscription[]

  @@unique([phone, orgId])
  @@index([orgId])
}

model ClientSubscription {
  id          String                   @id @default(cuid())
  orgId       String
  org         Organization             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  cycle       SLACycle                 @default(ANNUAL)
  startDate   DateTime
  renewalDate DateTime
  amountPaid  Float                    @default(0)
  currency    String                   @default("UGX")
  status      ClientSubscriptionStatus @default(ACTIVE)
  notes       String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  renewals  ClientSubscriptionRenewal[]
  reminders ClientSubscriptionReminder[]

  @@index([orgId, status, renewalDate])
  @@index([clientId, renewalDate])
}

model ClientSubscriptionRenewal {
  id             String             @id @default(cuid())
  subscriptionId String
  subscription   ClientSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  renewedAt      DateTime           @default(now())
  previousRenewalDate DateTime?
  nextRenewalDate     DateTime
  amountPaid     Float              @default(0)
  currency       String             @default("UGX")
  note           String?

  @@index([subscriptionId, renewedAt])
}

model ClientSubscriptionReminder {
  id             String                         @id @default(cuid())
  subscriptionId String
  subscription   ClientSubscription             @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  type           ClientSubscriptionReminderType
  remindAt       DateTime
  visible        Boolean                        @default(true)
  emailEnabled   Boolean                        @default(true)
  whatsappEnabled Boolean                       @default(true)
  emailSentAt    DateTime?
  whatsappSentAt DateTime?
  createdAt      DateTime                       @default(now())

  @@unique([subscriptionId, type, remindAt])
  @@index([remindAt, visible])
}

model Device {
  id       String        @id @default(cuid())
  clientId String
  client   Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  orgId    String?
  org      Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  deviceType    DeviceType
  brand         String
  model         String
  serialOrImei  String?
  accessories   String?
  physicalNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs Job[]

  @@index([clientId])
  @@index([orgId])
  @@index([serialOrImei])
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())
}

model Job {
  id            String        @id @default(cuid())
  jobNumber     String        @unique
  status        JobStatus     @default(RECEIVED)
  repairPath    RepairPath?
  orgId         String?
  org           Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  branchId      String?
  branch        Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])
  deviceId      String?
  device        Device?       @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  createdById   String
  createdBy     User          @relation("CreatedBy", fields: [createdById], references: [id])
  assignedToId  String?
  assignedTo    User?         @relation("AssignedTo", fields: [assignedToId], references: [id])
  deviceType    DeviceType
  brand         String
  model         String
  serialOrImei  String?
  accessories   String?
  physicalNotes String?

  // Business line: hardware repair vs software-only services.
  serviceType ServiceType @default(HARDWARE)

  // Software service scope (no app catalog; client must provide valid licenses).
  softwareOsInstall           Boolean                  @default(false)
  softwareDriversUpdates      Boolean                  @default(false)
  softwareDataBackupRestore   Boolean                  @default(false)
  softwareAccountSetup        Boolean                  @default(false)
  softwarePerformanceTune     Boolean                  @default(false)
  softwareThirdPartyApps      Boolean                  @default(false)
  softwareRequestedNotes      String?
  softwareLicenseAttested     Boolean                  @default(false)
  softwareInstallerSource     SoftwareInstallerSource?
  softwareInstallerSourceNote String?

  issueDescription       String
  workflowReason         WorkflowReason        @default(NONE)
  statusNote             String?
  diagnosisNotes         String?
  externalDiagnosis      String?
  recommendedRepair      String?
  recommendationOption   RecommendationOption?
  communicationStatus    CommunicationStatus   @default(NONE)
  clientConversationNote String?
  lastClientContactAt    DateTime?
  partsNeeded            String?

  externalTechBill   Float?    @map("costEstimate")
  clientBill         Float?    @map("finalCost")
  vatApplicable      Boolean   @default(true)
  externalTechFee    Float?
  externalPaid       Boolean   @default(false)
  externalPaidAt     DateTime?
  externalPaidById   String?
  externalPaidBy     User?     @relation("PayoutMarkedBy", fields: [externalPaidById], references: [id])
  externalPaymentRef String?
  clientPaid         Boolean   @default(false)
  clientPaidAt       DateTime?
  clientPaidById     String?
  clientPaidBy       User?     @relation("ClientPaymentMarkedBy", fields: [clientPaidById], references: [id])
  clientPaymentRef   String?
  invoiceNumber      String?   @unique
  invoiceIssuedAt    DateTime?
  clientApproved     Boolean?
  approvalDate       DateTime?
  quotedAt           DateTime?

  repairTimeline     String?
  timelineMinMinutes Int?
  timelineMaxMinutes Int?
  timelineConfidence TimelineConfidence?
  timelineNote       String?
  technicianNotes    String?
  workDone           String?
  partsReplaced      String?

  receivedAt     DateTime        @default(now())
  completedAt    DateTime?
  deliveredAt    DateTime?
  deliveryMethod DeliveryMethod? // PICKUP, DELIVERY, COURIER
  deliveredTo    String? // name of person who received
  closedAt       DateTime?
  updatedAt      DateTime        @updatedAt

  photos                    Photo[]
  auditLogs                 AuditLog[]
  notifications             Notification[]
  oneTimeExternalAssignment OneTimeExternalTechAssignment?
  outboundMessages          OutboundMessage[]
  inboundMessages           InboundMessage[]
  partReservations          PartReservation[]
  stockTransactions         PartStockTransaction[]
  quotations                Quotation[]   @relation("JobQuotation")
  fieldVisits               FieldVisit[]  @relation("JobFieldVisits")
  technicianPayouts         TechnicianPayout[]

  invoice    Invoice?
  complaints Complaint[]

  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, completedAt])
  @@index([orgId, receivedAt])
  @@index([orgId, repairPath, status])
  @@index([deviceId])
  @@index([clientId])
  @@index([createdById])
  @@index([status, updatedAt])
  @@index([status, receivedAt])
  @@index([assignedToId, status])
  @@index([completedAt])
  @@index([repairPath])
}

model Invoice {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Repair invoices link to a Job; standalone invoices link directly to a Client.
  jobId    String?  @unique
  job      Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  clientId String?
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  ticket     Ticket?  @relation("TicketInvoice")

  invoiceType   InvoiceType   @default(REPAIR)
  subject       String?
  dueDate       DateTime?

  invoiceNumber String        @unique
  currency      String        @default("UGX")
  status        InvoiceStatus @default(ISSUED)
  issuedAt      DateTime      @default(now())
  totalAmount   Float

  paidAmount Float     @default(0)
  paidAt     DateTime?

  notes String?

  lines         InvoiceLine[]
  payments      Payment[]
  refunds       Refund[]
  deliveryNotes DeliveryNote[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([orgId, issuedAt])
  @@index([orgId, status])
  @@index([orgId, invoiceType])
  @@index([clientId])
}

model Payment {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  saleId String?
  sale   Sale?   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  currency           String @default("UGX")
  exchangeRateToBase Float? // when currency != org.baseCurrency

  amount     Float
  method     PaymentMethod @default(CASH)
  kind       String        @default("PAYMENT")
  reference  String?
  receivedAt DateTime      @default(now())

  createdById String?
  createdBy   User?   @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  note      String?
  createdAt DateTime @default(now())

  @@index([orgId, receivedAt])
  @@index([orgId, kind, receivedAt])
  @@index([invoiceId])
  @@index([saleId])
}

model TechnicianPayout {
  id           String        @id @default(cuid())
  orgId        String
  jobId        String
  job          Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  amount       Float
  method       PaymentMethod @default(CASH)
  reference    String?
  note         String?
  paidAt       DateTime      @default(now())
  recordedById String?
  recordedBy   User?         @relation("TechnicianPayoutRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())

  @@index([orgId, paidAt])
  @@index([jobId])
}

model Refund {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Refund can relate to either a Sale (merchandise) or an Invoice (repairs).
  saleId       String?
  sale         Sale?       @relation(fields: [saleId], references: [id], onDelete: Cascade)
  invoiceId    String?
  invoice      Invoice?    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  creditNoteId String?
  creditNote   CreditNote? @relation(fields: [creditNoteId], references: [id], onDelete: SetNull)

  currency           String @default("UGX")
  exchangeRateToBase Float?
  amount             Float
  method             PaymentMethod @default(CASH)
  reference          String?
  refundedAt         DateTime      @default(now())
  createdById        String
  createdBy          User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  note               String?
  createdAt          DateTime      @default(now())

  @@index([orgId, refundedAt])
  @@index([saleId])
  @@index([invoiceId])
  @@index([creditNoteId])
}

model CreditNote {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Credit notes are for merchandise sales only (Sale-based).
  saleId String
  sale   Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  creditNoteNumber String   @unique
  currency         String   @default("UGX")
  totalAmount      Float
  issuedAt         DateTime @default(now())
  reason           String?

  // Stock return is only applied when items are physically received back.
  itemsReceivedBackAt  DateTime?
  itemsReceivedBackById String?
  itemsReceivedBackBy   User?     @relation("CreditNoteReceivedBackBy", fields: [itemsReceivedBackById], references: [id], onDelete: SetNull)
  itemsReceivedBackNote String?

  createdById String
  createdBy   User   @relation("CreditNoteCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  items   CreditNoteItem[]
  refunds Refund[]

  @@index([orgId, issuedAt])
  @@index([saleId])
}

model CreditNoteItem {
  id           String     @id @default(cuid())
  creditNoteId String
  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  partId       String?
  part         Part?      @relation(fields: [partId], references: [id], onDelete: SetNull)
  description  String
  quantity     Int
  unitPrice    Float
  lineTotal    Float

  createdAt DateTime @default(now())

  @@index([creditNoteId])
  @@index([partId])
}

model Sale {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  posSessionId String?
  posSession   PosSession? @relation(fields: [posSessionId], references: [id], onDelete: SetNull)

  status     SaleStatus @default(OPEN)
  saleNumber String     @unique

  billingMode SaleBillingMode @default(CASH)
  invoiceNumber String?
  invoicedAt    DateTime?

  currency String @default("UGX")

  subtotal       Float     @default(0)
  discountAmount Float     @default(0)
  vatAmount      Float     @default(0)
  totalAmount    Float     @default(0)
  paidAmount     Float     @default(0)
  paidAt         DateTime?

  notes String?

  items             SaleItem[]
  payments          Payment[]
  refunds           Refund[]
  creditNotes       CreditNote[]
  deliveryNotes     DeliveryNote[]
  stockTransactions PartStockTransaction[]

  createdById String?
  createdBy   User?   @relation("SaleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, createdAt])
  @@index([orgId, status])
  @@index([branchId])
  @@index([clientId])
  @@index([posSessionId])
}

model DeliveryNote {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  saleId String?
  sale   Sale?   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  deliveryNoteNumber String   @unique
  deliveredAt        DateTime @default(now())
  deliveryMethod     DeliveryMethod?

  deliveredByName String
  receivedByName  String
  receivedBySignatureText String?

  note String?
  createdById String?
  createdBy   User?   @relation("DeliveryNoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  items DeliveryNoteItem[]

  @@index([orgId, deliveredAt])
  @@index([saleId])
  @@index([invoiceId])
}

model DeliveryNoteItem {
  id             String       @id @default(cuid())
  deliveryNoteId String
  deliveryNote   DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)

  saleItemId  String?
  saleItem    SaleItem? @relation(fields: [saleItemId], references: [id], onDelete: SetNull)

