  @@index([paymentId])
  @@index([clientId])
}

model PaymentAllocation {
  id          String   @id @default(cuid())
  orgId       String
  paymentId   String
  targetType  String
  targetId    String
  amount      Float
  allocatedAt DateTime @default(now())
  note        String?

  @@index([orgId, paymentId])
  @@index([targetType, targetId])
}

model CashierShift {
  id           String    @id @default(cuid())
  orgId        String
  branchId     String?
  posSessionId String?
  cashierId    String
  status       String    @default("OPEN")
  shiftPin     String?
  openingCash  Float     @default(0)
  closingCash  Float?
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  notes        String?

  @@index([orgId, branchId, status])
  @@index([cashierId, openedAt])
}

model Conversation {
  id              String    @id @default(cuid())
  orgId           String
  channel         String
  clientId        String?
  jobId           String?
  repairRequestId String?
  assignedToId    String?
  status          String    @default("OPEN")
  subject         String?
  lastMessageAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([orgId, status, lastMessageAt])
  @@index([clientId])
  @@index([jobId])
}

model ConversationMessage {
  id                String    @id @default(cuid())
  orgId             String
  conversationId    String
  direction         String
  channel           String
  sender            String?
  recipient         String?
  body              String?
  outboundMessageId String?
  inboundMessageId  String?
  providerMessageId String?
  sentAt            DateTime?
  receivedAt        DateTime?
  createdAt         DateTime  @default(now())

  @@index([orgId, conversationId, createdAt])
  @@index([providerMessageId])
}

model CommunicationTemplateVersion {
  id          String    @id @default(cuid())
  orgId       String?
  templateId  String
  version     Int
  status      String    @default("DRAFT")
  subject     String?
  body        String
  variables   String?
  approvedAt  DateTime?
  createdById String?
  createdAt   DateTime  @default(now())

  @@unique([templateId, version])
  @@index([orgId, status])
}

model FileAsset {
  id           String    @id @default(cuid())
  orgId        String
  ownerType    String
  ownerId      String
  url          String
  storageKey   String?
  fileName     String?
  mimeType     String?
  sizeBytes    Int?
  label        String?
  visibility   String    @default("INTERNAL")
  uploadedById String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([orgId, ownerType, ownerId])
  @@index([storageKey])
}

// ── COMPLAINTS (ISO 10002:2018) ───────────────────────────────────────────────

enum ComplaintStatus {
  RECEIVED
  ACKNOWLEDGED
  INVESTIGATING
  RESOLVED
  CLOSED
}

enum ComplaintCategory {
  SERVICE_QUALITY
  REPAIR_DELAY
  BILLING
  STAFF_CONDUCT
  DAMAGE_CAUSED
  UNRESOLVED_FAULT
  OTHER
}

enum ComplaintChannel {
  WEB
  WALK_IN
  PHONE
  WHATSAPP
  EMAIL
}

model Complaint {
  id              String            @id @default(cuid())
  orgId           String
  org             Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  complaintNumber String            @unique // CMP-YYYY-XXXX
  status          ComplaintStatus   @default(RECEIVED)
  category        ComplaintCategory @default(OTHER)
  channel         ComplaintChannel  @default(WEB)

  // Linked reference (one or the other)
  jobId  String?
  job    Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)
  saleId String?

  // Complainant info
  clientName  String
  clientPhone String
  clientEmail String?

  // Complaint content
  description        String
  expectedResolution String?

  // Internal workflow
  assignedToId  String?
  assignedTo    User?   @relation("ComplaintAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  internalNotes String?
  resolution    String?

  // ISO 10002 SLA timestamps
  acknowledgedAt  DateTime?
  investigatingAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?

  // Satisfaction follow-up
  satisfactionRating  Int?
  satisfactionComment String?
  ratedAt             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status, createdAt])
  @@index([orgId, createdAt])
  @@index([jobId])
}

// ── Sales Targets ───────────────────────────────────────────────────────────
// Monthly revenue targets. userId = null means a team/org-level target.
// period = "YYYY-MM" e.g. "2026-05"
enum TargetEntityType {
  USER
  INDIVIDUAL
  DEPARTMENT
  BRANCH
  COMPANY
}

enum TargetMetric {
  REVENUE
  JOBS_COMPLETED
  LEADS_CONVERTED
  SALES_COUNT
  QUOTATIONS_SENT
  POS_SALES
  CUSTOMER_SATISFACTION
  RESPONSE_TIME_HOURS
}

enum TargetPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUAL
  YEARLY
}

model SalesTarget {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation("SalesTargets", fields: [userId], references: [id], onDelete: SetNull)

  departmentId String?
  department   Department? @relation("DeptSalesTargets", fields: [departmentId], references: [id], onDelete: SetNull)

  branchId String?
  branch   Branch? @relation("BranchSalesTargets", fields: [branchId], references: [id], onDelete: SetNull)

  setById String?
  setBy   User? @relation("TargetSetBy", fields: [setById], references: [id], onDelete: SetNull)

  entityType  TargetEntityType @default(COMPANY)
  metric      TargetMetric     @default(REVENUE)
  period      String           // "YYYY-MM" or enum label, depending on source
  periodLabel String?

  // Legacy commercial target fields remain for dashboard/report compatibility.
  targetRevenue Float @default(0)
  targetJobs    Int   @default(0)

  targetValue Float @default(0)
  actualValue Float @default(0)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, userId, period])
  @@index([orgId, period])
  @@index([entityType, period, periodLabel])
  @@index([userId])
  @@index([departmentId])
  @@index([branchId])
}

// ── Sales CRM / field work / POS sessions ───────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  WON
  LOST
  STALE
}

enum LeadSource {
  WALK_IN
  REFERRAL
  PHONE
  SOCIAL_MEDIA
  WEBSITE
  OTHER
}

model Lead {
  id        String       @id @default(cuid())
  orgId     String?
  org       Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  branchId  String?
  branch    Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)

  fullName     String
  phone        String
  email        String?
  organization String?
  interest     String?
  source       LeadSource @default(WALK_IN)
  status       LeadStatus @default(NEW)
  estimatedValue Float?
  score        Int     @default(0) // 0-100 lead quality score
  notes        String?
  lostReason   String? // e.g. "Price", "Competitor", "No Budget", "Timing", "Other"

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  assignedToId String?
  assignedTo   User? @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById  String?
  createdBy    User? @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  convertedAt DateTime?
  closedAt    DateTime?
  followUpAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activities       LeadActivity[]
  quotations       Quotation[]
  campaignContacts CampaignContact[]

  @@index([orgId, status])
  @@index([assignedToId])
  @@index([createdAt])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("LeadActivityBy", fields: [userId], references: [id], onDelete: Cascade)
  type      String
  note      String
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
  @@index([userId, createdAt])
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quotation {
  id          String          @id @default(cuid())
  orgId       String?
  org         Organization?   @relation(fields: [orgId], references: [id], onDelete: SetNull)
  quoteNumber String          @unique
  status      QuotationStatus @default(DRAFT)
  currency    String          @default("UGX")

  leadId   String?
  lead     Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  jobId    String?
  job      Job?    @relation("JobQuotation", fields: [jobId], references: [id], onDelete: SetNull)
  ticket     Ticket?   @relation("TicketQuotation")

  subtotal    Float @default(0)
  discountAmount Float @default(0)
  vatAmount      Float @default(0)
  taxLabel       String?
  taxRate        Float?
  totalAmount Float @default(0)
  notes       String?
  validUntil  DateTime?
  sentAt      DateTime?
  acceptedAt  DateTime?
  rejectedAt  DateTime?

  createdById String?
  createdBy   User? @relation("QuotationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvedById String?
  approvedBy   User? @relation("QuotationApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  convertedToInvoiceId String? @unique

  items     QuotationItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([leadId])
  @@index([clientId])
  @@index([jobId])
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  partId      String?
  part        Part?     @relation("PartQuotationItems", fields: [partId], references: [id], onDelete: SetNull)
  description String
  quantity    Int
  unitPrice   Float
  discount    Float     @default(0)
  lineTotal   Float
  createdAt   DateTime  @default(now())

  @@index([quotationId])
  @@index([partId])
}

enum PosSessionStatus {
  OPEN
  CLOSED
}

model PosSession {
  id         String           @id @default(cuid())
  orgId      String?
  org        Organization?    @relation(fields: [orgId], references: [id], onDelete: SetNull)
  branchId   String?
  branch     Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  operatorId String
  operator   User             @relation("PosSessionOperator", fields: [operatorId], references: [id], onDelete: Cascade)
  status     PosSessionStatus @default(OPEN)
  openingFloat Float          @default(0)
  closingCash  Float?
  cashTotal    Float          @default(0)
  cardTotal    Float          @default(0)
  mobileTotal  Float          @default(0)
  totalSales   Float          @default(0)
  salesCount   Int            @default(0)
  actualClosingBalance Float?
  openedAt     DateTime       @default(now())
  closedAt     DateTime?
  notes        String?

  sales Sale[]

  @@index([orgId, status])
  @@index([operatorId, openedAt])
  @@index([branchId])
}

enum FieldVisitType {
  COLLECTION
  DELIVERY
  ONSITE_REPAIR
  ASSESSMENT
  FOLLOWUP
}

enum FieldVisitStatus {
  SCHEDULED
  EN_ROUTE
  ARRIVED
  COMPLETED
  CANCELLED
  FAILED
}

model FieldVisit {
  id       String           @id @default(cuid())
  orgId    String?
  org      Organization?    @relation(fields: [orgId], references: [id], onDelete: SetNull)
  branchId String?
  branch   Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  jobId    String?
  job      Job?             @relation("JobFieldVisits", fields: [jobId], references: [id], onDelete: SetNull)

  assignedToId String
  assignedTo   User   @relation("FieldVisitAssignedTo", fields: [assignedToId], references: [id], onDelete: Cascade)
  scheduledById String
  scheduledBy   User   @relation("FieldVisitScheduledBy", fields: [scheduledById], references: [id], onDelete: Cascade)

  type      FieldVisitType
  status    FieldVisitStatus @default(SCHEDULED)
  scheduledAt DateTime
  startedAt   DateTime?
  arrivedAt   DateTime?
  completedAt DateTime?

  address      String
  gpsLat       Float?
  gpsLng       Float?
  contactName  String?
  contactPhone String?
  notes        String?
  outcomeNotes String?
  signoffName  String?
  signoffAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([assignedToId, scheduledAt])
  @@index([jobId])
  @@index([branchId])
}

// ── ACCOUNTING (Double-Entry) ─────────────────────────────────────────────────

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model ChartOfAccount {
  id          String      @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  code        String      // e.g. "1000"
  name        String
  type        AccountType
  parentId    String?
  parent      ChartOfAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    ChartOfAccount[] @relation("AccountHierarchy")
  description String?
  isSystem    Boolean     @default(false) // system accounts can't be deleted
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  journalLines JournalLine[]

  @@unique([orgId, code])
  @@index([orgId, type])
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOID
}

model JournalEntry {
  id          String             @id @default(cuid())
  orgId       String
  org         Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  entryNumber String             // JE-YYYY-XXXX
  date        DateTime
  description String
  reference   String?            // invoice/expense/etc ref
  status      JournalEntryStatus @default(DRAFT)
  totalAmount Float              @default(0)
  createdById String
  createdBy   User               @relation("JournalEntryCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  postedAt    DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  lines JournalLine[]

  @@unique([orgId, entryNumber])
  @@index([orgId, date])
  @@index([orgId, status])
}

model JournalLine {
  id             String         @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        ChartOfAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  debit          Float          @default(0)
  credit         Float          @default(0)
  description    String?

  @@index([journalEntryId])
  @@index([accountId])
}

model BankAccount {
  id             String       @id @default(cuid())
  orgId          String
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name           String
  accountNumber  String?
  bankName       String
  currency       String       @default("UGX")
  openingBalance Float        @default(0)
  currentBalance Float        @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  transactions BankTransaction[]

  @@index([orgId])
}

enum BankTransactionType {
  CREDIT
  DEBIT
}

model BankTransaction {
  id            String              @id @default(cuid())
  bankAccountId String
  bankAccount   BankAccount         @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  orgId         String
  org           Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  date          DateTime
  description   String
  amount        Float               // positive always; type distinguishes direction
  type          BankTransactionType
  reference     String?
  reconciledAt  DateTime?
  createdAt     DateTime            @default(now())

  @@index([bankAccountId, date])
  @@index([orgId, date])
}

// ── CRM — Campaigns & Lead Scoring ───────────────────────────────────────────

enum CampaignType {
  EMAIL
  SMS
  CALL
  WHATSAPP
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum CampaignContactStatus {
  PENDING
  SENT
  OPENED
  RESPONDED
  OPTED_OUT
}

model Campaign {
  id          String         @id @default(cuid())
  orgId       String
  org         Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  type        CampaignType
  status      CampaignStatus @default(DRAFT)
  subject     String?        // email subject line
  body        String         // message body / template
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdById String
  createdBy   User           @relation("CampaignCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  contacts CampaignContact[]

  @@index([orgId, status])
}

model CampaignContact {
  id         String                @id @default(cuid())
  campaignId String
  campaign   Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  orgId      String
  // target is either a lead or an existing client
  leadId     String?
  lead       Lead?                 @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clientId   String?
  client     Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  status     CampaignContactStatus @default(PENDING)
  sentAt     DateTime?
  openedAt   DateTime?
  repliedAt  DateTime?
  createdAt  DateTime              @default(now())

  @@unique([campaignId, leadId])
  @@unique([campaignId, clientId])
  @@index([campaignId, status])
}

// ── AI Knowledge & Feedback ──────────────────────────────────────────────────

model AiKnowledgeArticle {
  id        String   @id @default(cuid())
  orgId     String?
  title     String
  module    String
  content   String
  embeddingJson String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, module, isActive])
  @@index([isActive, updatedAt])
}

model AiFeedback {
  id        String   @id @default(cuid())
  orgId     String?
  userId    String?
  feature   String
  question  String
  answer    String
  rating    String
  comment   String?
  createdAt DateTime @default(now())

  @@index([orgId, feature, createdAt])
  @@index([rating, createdAt])
}

model AiPromptLog {
  id              String   @id @default(cuid())
  orgId           String?
  userId          String?
  feature         String
  promptVersion   String
  model           String?
  questionRedacted String
  contextSummary  String?
  mode            String
  createdAt       DateTime @default(now())

  @@index([orgId, feature, createdAt])
  @@index([promptVersion, createdAt])
}

model AiOrgSettings {
  orgId                    String   @id
  aiEnabled                Boolean  @default(true)
  guideEnabled             Boolean  @default(true)
  insightsEnabled          Boolean  @default(true)
  allowOrgKnowledge        Boolean  @default(true)
  allowPromptLogging       Boolean  @default(true)
  model                    String?
  updatedAt                DateTime @updatedAt
}
