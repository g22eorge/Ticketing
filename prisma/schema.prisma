// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Branch {
  id           String   @id @default(cuid())
  orgId        String?
  name         String
  address      String?
  phone        String?
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users           User[]
  posSessions     PosSession[]
  sales           Sale[]
  leads           Lead[]
  salesTargets    SalesTarget[]  @relation("BranchSalesTargets")
  fieldVisits     FieldVisit[]

  @@index([isActive])
  @@index([orgId])
}

model Department {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())

  users        User[]
  salesTargets SalesTarget[] @relation("DeptSalesTargets")
}

model User {
  id              String      @id @default(cuid())
  name            String
  email           String      @unique
  phone           String?
  emailVerified   Boolean     @default(false)
  image           String?
  role            Role        @default(OPS)
  isActive        Boolean     @default(true)
  // Org structure
  branchId        String?
  branch          Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  // Tech-specific
  techType        TechType?
  employeeId      String?
  specializations String?     // JSON array e.g. ["phones","laptops"]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  sessions     Session[]
  accounts     Account[]
  permissionGrants UserPermission[]
  jobsCreated  Job[]      @relation("CreatedBy")
  jobsAssigned Job[]      @relation("AssignedTo")
  payoutsMarked Job[]     @relation("PayoutMarkedBy")
  clientPaymentsMarked Job[] @relation("ClientPaymentMarkedBy")
  auditLogs    AuditLog[]
  clientNotes  ClientNote[]
  notifications Notification[]
  notificationPreferences NotificationPreferences?
  partReservations PartReservation[] @relation("PartReservedBy")
  stockTransactions PartStockTransaction[] @relation("StockTxnBy")
  accessAuditEntries UserAccessAudit[] @relation("AccessAuditTarget")
  accessAuditChanges UserAccessAudit[] @relation("AccessAuditActor")
  posSessionsOperated PosSession[]      @relation("PosSessionOperator")
  salesCreated        Sale[]            @relation("SaleCreatedBy")
  paymentsCreated     Payment[]         @relation("PaymentCreatedBy")
  refundsCreated      Refund[]          @relation("RefundCreatedBy")
  leadsCreated        Lead[]            @relation("LeadCreatedBy")
  leadsAssigned       Lead[]            @relation("LeadAssignedTo")
  leadActivities      LeadActivity[]    @relation("LeadActivityBy")
  quotationsCreated   Quotation[]       @relation("QuotationCreatedBy")
  quotationsApproved  Quotation[]       @relation("QuotationApprovedBy")
  salesTargets        SalesTarget[]     @relation("UserSalesTargets")
  targetsSet          SalesTarget[]     @relation("TargetSetBy")
  fieldVisitsAssigned FieldVisit[]      @relation("FieldVisitAssignedTo")
  fieldVisitsScheduled FieldVisit[]     @relation("FieldVisitScheduledBy")

  @@index([role, isActive])
  @@index([branchId])
  @@index([departmentId])
}

model UserPermission {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission String
  createdAt  DateTime @default(now())

  @@unique([userId, permission])
  @@index([permission])
}

model UserAccessAudit {
  id           String   @id @default(cuid())
  targetUserId String
  targetUser   User     @relation("AccessAuditTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  actorUserId  String
  actorUser    User     @relation("AccessAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  action       String
  detail       String?
  createdAt    DateTime @default(now())

  @@index([targetUserId, createdAt])
  @@index([actorUserId, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum Role {
  ADMIN
  OPS
  TECHNICIAN_INTERNAL
  TECHNICIAN_EXTERNAL
  FRONT_DESK
  SALES_MANAGER
  TECH_MANAGER
  SALES_CORPORATE
  SALES_RETAIL
  SALES_POS
  TECH_FIELD
  FINANCE
  // Legacy: kept for existing production rows.
  // The app normalizes this to FRONT_DESK at runtime.
  INTAKE
}

enum TechType {
  INTERNAL
  EXTERNAL_PERMANENT
  EXTERNAL_ONE_TIME
  FIELD
}

enum JobStatus {
  RECEIVED
  DIAGNOSING
  REFERRED
  PENDING_EXTERNAL_ASSIGNMENT
  ASSIGNED_ONE_TIME_EXTERNAL
  IN_EXTERNAL_REPAIR
  WAITING_FOR_PARTS
  RETURNED_FROM_EXTERNAL
  AWAITING_APPROVAL
  IN_REPAIR
  READY_FOR_PICKUP
  DELIVERED
  COMPLETED
  CLOSED
}

enum RecommendationOption {
  PROCEED_REPAIR
  REPLACE_DEVICE
  RETURN_UNREPAIRED
}

enum CommunicationStatus {
  NONE
  AWAITING_RESPONSE
  APPROVED
  DECLINED
}

enum RepairPath {
  IN_HOUSE
  EXTERNAL
}

enum ServiceType {
  HARDWARE
  SOFTWARE
  BOTH
}

enum SoftwareInstallerSource {
  CLIENT_PROVIDED_INSTALLER
  CLIENT_ACCOUNT_LOGIN
  COMPANY_LICENSE
  OPEN_SOURCE
  OTHER
}

enum DeliveryMethod {
  PICKUP
  DELIVERY
  COURIER
}

enum DeviceType {
  PHONE_ANDROID
  PHONE_IPHONE
  TABLET
  WINDOWS_PC
  MAC
  OTHER
}

enum TimelineConfidence {
  FIRM
  ESTIMATED
  PARTS_DEPENDENT
}

enum WorkflowReason {
  NONE
  PARTS_PENDING
  SPECIALIST_ESCALATION
  CLIENT_DECLINED
  UNREPAIRABLE
  CUSTOMER_CANCELLED
  OTHER
}

enum PartReservationStatus {
  RESERVED
  CONSUMED
  RELEASED
}

enum StockTransactionType {
  IN
  OUT
  ADJUST
}

model Client {
  id           String   @id @default(cuid())
  orgId        String?
  fullName     String
  phone        String   @unique
  email        String?
  organization String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobs            Job[]
  devices         Device[]
  notesEntries    ClientNote[]
  inboundMessages InboundMessage[]
  sales           Sale[]
  leads           Lead[]
  quotations      Quotation[]
}

model Device {
  id           String     @id @default(cuid())
  clientId     String
  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  deviceType   DeviceType
  brand        String
  model        String
  serialOrImei String?
  accessories  String?
  physicalNotes String?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  jobs         Job[]

  @@index([clientId])
  @@index([serialOrImei])
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())
}

model Job {
  id            String     @id @default(cuid())
  jobNumber     String     @unique
  status        JobStatus  @default(RECEIVED)
  repairPath    RepairPath?
  clientId      String
  client        Client     @relation(fields: [clientId], references: [id])
  deviceId      String?
  device        Device?    @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  createdById   String
  createdBy     User       @relation("CreatedBy", fields: [createdById], references: [id])
  assignedToId  String?
  assignedTo    User?      @relation("AssignedTo", fields: [assignedToId], references: [id])
  deviceType    DeviceType
  brand         String
  model         String
  serialOrImei  String?
  accessories   String?
  physicalNotes String?

  // Business line: hardware repair vs software-only services.
  serviceType   ServiceType @default(HARDWARE)

  // Software service scope (no app catalog; client must provide valid licenses).
  softwareOsInstall          Boolean @default(false)
  softwareDriversUpdates     Boolean @default(false)
  softwareDataBackupRestore  Boolean @default(false)
  softwareAccountSetup       Boolean @default(false)
  softwarePerformanceTune    Boolean @default(false)
  softwareThirdPartyApps     Boolean @default(false)
  softwareRequestedNotes     String?
  softwareLicenseAttested    Boolean @default(false)
  softwareInstallerSource    SoftwareInstallerSource?
  softwareInstallerSourceNote String?

  issueDescription  String
  workflowReason    WorkflowReason @default(NONE)
  statusNote        String?
  diagnosisNotes    String?
  externalDiagnosis String?
  recommendedRepair String?
  recommendationOption RecommendationOption?
  communicationStatus CommunicationStatus @default(NONE)
  clientConversationNote String?
  lastClientContactAt DateTime?
  partsNeeded       String?

  externalTechBill Float? @map("costEstimate")
  clientBill       Float? @map("finalCost")
  vatApplicable    Boolean @default(true)
  externalTechFee Float?
  externalPaid    Boolean   @default(false)
  externalPaidAt  DateTime?
  externalPaidById String?
  externalPaidBy  User?     @relation("PayoutMarkedBy", fields: [externalPaidById], references: [id])
  externalPaymentRef String?
  clientPaid      Boolean   @default(false)
  clientPaidAt    DateTime?
  clientPaidById  String?
  clientPaidBy    User?     @relation("ClientPaymentMarkedBy", fields: [clientPaidById], references: [id])
  clientPaymentRef String?
  invoiceNumber   String?   @unique
  invoiceIssuedAt DateTime?
  clientApproved Boolean?
  approvalDate   DateTime?
  quotedAt       DateTime?

  repairTimeline  String?
  timelineMinMinutes Int?
  timelineMaxMinutes Int?
  timelineConfidence TimelineConfidence?
  timelineNote String?
  technicianNotes String?
  workDone        String?
  partsReplaced   String?

  receivedAt  DateTime  @default(now())
  completedAt DateTime?
  deliveredAt DateTime?
  deliveryMethod DeliveryMethod? // PICKUP, DELIVERY, COURIER
  deliveredTo String? // name of person who received
  closedAt    DateTime?
  updatedAt   DateTime  @updatedAt

  photos    Photo[]
  auditLogs AuditLog[]
  notifications Notification[]
  oneTimeExternalAssignment OneTimeExternalTechAssignment?
  outboundMessages OutboundMessage[]
  inboundMessages  InboundMessage[]
  partReservations PartReservation[]
  stockTransactions PartStockTransaction[]
  invoice      Invoice?
  quotations   Quotation[]   @relation("JobQuotation")
  fieldVisits  FieldVisit[]  @relation("JobFieldVisits")

  @@index([deviceId])
  @@index([clientId])
  @@index([createdById])
  @@index([status, updatedAt])
  @@index([status, receivedAt])
  @@index([assignedToId, status])
  @@index([completedAt])
  @@index([repairPath])
}

model Part {
  id             String   @id @default(cuid())
  sku            String   @unique
  name           String
  manufacturer   String?
  unitCost       Float?
  qtyOnHand      Int      @default(0)
  reorderLevel   Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  reservations   PartReservation[]
  transactions   PartStockTransaction[]
  saleItems      SaleItem[]
  quotationItems QuotationItem[] @relation("PartQuotationItems")

  @@index([isActive])
}

model PartReservation {
  id             String                @id @default(cuid())
  jobId           String
  job             Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  partId          String
  part            Part                  @relation(fields: [partId], references: [id], onDelete: Restrict)
  quantity        Int
  status          PartReservationStatus @default(RESERVED)
  unitCostSnapshot Float?
  reservedById    String?
  reservedBy      User?                 @relation("PartReservedBy", fields: [reservedById], references: [id], onDelete: SetNull)
  reservedAt      DateTime              @default(now())
  consumedAt      DateTime?
  releasedAt      DateTime?
  note            String?

  @@index([jobId, status])
  @@index([partId, status])
}

model PartStockTransaction {
  id             String               @id @default(cuid())
  partId          String
  part            Part                 @relation(fields: [partId], references: [id], onDelete: Cascade)
  type            StockTransactionType
  quantity        Int
  reason          String?
  jobId           String?
  job             Job?                 @relation(fields: [jobId], references: [id], onDelete: SetNull)
  createdById     String?
  createdBy       User?                @relation("StockTxnBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime             @default(now())

  @@index([partId, createdAt])
  @@index([jobId])
}

model OneTimeExternalTechAssignment {
  id                String   @id @default(cuid())
  jobId             String   @unique
  job               Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  technicianName    String
  phone             String
  specialization    String?

  agreedRepairCost  Float?
  partsNotes        String?
  expectedPartsCost Float?

  assignedAt        DateTime
  expectedReturnAt  DateTime?
  returnedAt        DateTime?

  instructions      String?
  progressNotes     String?
  finalOutcome      String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([assignedAt])
}

model Photo {
  id         String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  url         String
  label       String?
  uploadedAt DateTime @default(now())

  @@index([jobId, uploadedAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  detail    String?
  createdAt DateTime @default(now())

  @@index([jobId, createdAt])
  @@index([userId, createdAt])
}

enum NotificationType {
  STATUS_CHANGE
  APPROVAL_NEEDED
  JOB_ASSIGNED
  ESTIMATE_SUBMITTED
  PAYMENT_RECEIVED
  PAYOUT_GENERATED
  TIMELINE_UPDATED
  DELAY_NOTE_ADDED
}

enum NotificationChannel {
  DASHBOARD
  WHATSAPP
  EMAIL
}

enum OutboundMessageChannel {
  WHATSAPP
  EMAIL
}

enum OutboundMessageStatus {
  PENDING
  SENT
  FAILED
  DEAD
}

enum OutboundMessageType {
  REPAIR_REQUEST_CONFIRMATION
  FRONT_DESK_APPROVED
  FRONT_DESK_REJECTED
  // Legacy: kept for existing production rows.
  // The app treats these as FRONT_DESK_*.
  INTAKE_APPROVED
  INTAKE_REJECTED
  JOB_CREATED
  JOB_COMPLETED
  JOB_STATUS_UPDATE
  READY_FOR_PICKUP_NUDGE_1
  READY_FOR_PICKUP_NUDGE_2
  REPAIR_REQUEST_EMAIL_ALERT
  ADMIN_TEST
  STAFF_REPLY
}

model Notification {
  id          String            @id @default(cuid())
  type        NotificationType
  title       String
  message     String
  jobId       String?
  job         Job?             @relation(fields: [jobId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel     NotificationChannel @default(DASHBOARD)
  isRead      Boolean          @default(false)
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  
  @@index([userId, isRead])
  @@index([jobId])
}

model OutboundMessage {
  id               String               @id @default(cuid())
  channel          OutboundMessageChannel
  status           OutboundMessageStatus @default(PENDING)
  type             OutboundMessageType

  to               String
  // EMAIL only. (Legacy rows may store the subject on the first line of `body`.)
  subject          String?
  body             String

  // Optional template metadata for observability/debugging.
  templateKey      String?
  // JSON string of the variables used to render the template at enqueue time.
  templateVars     String?
  // When set, this message is sent as a Meta-approved template message instead of free-form text.
  metaTemplateName     String?  // approved template name, e.g. "repair_status_update"
  metaTemplateLanguage String?  // language code, e.g. "en"
  // JSON array of parameter VALUES in positional order matching {{1}}, {{2}}… in the template body.
  metaTemplateVars     String?

  provider         String?
  providerMessageId String?

  // Provider delivery statuses (webhook callbacks). This does not affect outbox retry.
  providerDeliveryStatus String?
  providerDeliveryAt     DateTime?
  providerDeliveryErrorCode String?
  providerDeliveryError     String?

  attemptCount     Int                  @default(0)
  lastAttemptAt    DateTime?
  nextAttemptAt    DateTime             @default(now())
  sentAt           DateTime?

  lastErrorCode    String?
  lastError        String?

  lockedAt         DateTime?

  repairRequestId  String?
  repairRequest    RepairRequest?       @relation(fields: [repairRequestId], references: [id], onDelete: SetNull)
  jobId            String?
  job              Job?                 @relation(fields: [jobId], references: [id], onDelete: SetNull)

  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([channel, status, nextAttemptAt])
  @@index([providerMessageId])
  @@index([repairRequestId])
  @@index([jobId])
  @@index([templateKey])
}

model NotificationPreferences {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  notifyStatusChange  Boolean  @default(true)
  notifyApprovalNeeded Boolean @default(true)
  notifyJobAssigned   Boolean  @default(true)
  notifyEstimateSubmitted Boolean @default(true)
  notifyPaymentReceived Boolean @default(true)
  notifyPayoutGenerated Boolean @default(true)
  notifyTimelineUpdated Boolean @default(true)
  notifyDelayNote    Boolean  @default(true)
  
  whatsappEnabled     Boolean  @default(true)
  emailEnabled        Boolean  @default(false)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model CommunicationTemplate {
  id          String   @id @default(cuid())
  orgId       String?
  key         String
  channel     OutboundMessageChannel
  label       String
  subject     String?
  body        String
  // JSON array of placeholder keys in the ORDER they map to Meta template {{1}}, {{2}}…
  variables         String?
  // Meta / WhatsApp Business API template fields. Set these once the template is approved.
  metaTemplateName  String?  // approved template name in Meta, e.g. "repair_status_update"
  metaLanguageCode  String?  // e.g. "en" — defaults to "en" when metaTemplateName is set
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, channel])
  @@index([channel, isActive])
}

model CommunicationPolicy {
  id               String    @id @default(cuid())
  status           JobStatus @unique
  dashboardEnabled Boolean   @default(true)
  whatsappEnabled  Boolean   @default(false)
  emailEnabled     Boolean   @default(false)
  // Shared key; can map to channel-specific templates with the same key.
  templateKey      String?
  nudge1Hours      Int?
  nudge2Hours      Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([templateKey])
}

model DocumentBrandingSettings {
  id                   String   @id @default("singleton")
  companyName          String   @default("Eagle Info Solutions")
  companyTagline       String?
  companyAddressLine1  String   @default("Nalubega Complex, 1st Floor")
  companyAddressLine2  String   @default("Shop L28, Bombo Road Opposite Watoto Church")
  companyContacts      String   @default("+256772 006 344 | +256754 006 344")
  companyEmail         String?
  companyWebsite       String?
  documentTitle        String   @default("Job Card")
  quotePrefix          String   @default("EIS")
  quoteFormat          String   @default("{PREFIX} {M}/{YYYY}/{SEQ}")
  quoteValidityDays    Int      @default(30)
  sequencePadLength    Int      @default(4)
  vatDefaultApplicable Boolean  @default(true)
  vatRatePercent       Float    @default(18)
  vatLabel             String   @default("VAT")
  termsText            String   @default("Quotation valid for 30 days from date issued.\nRepair work begins only after approval is recorded.\nParts availability may affect final timeline.\nHidden pre-existing faults may affect final outcome.\nUncollected devices may attract storage fees after notice.")
  footerText           String   @default("System built by Almeida @ 2026 all rights reserved.")
  signatureCompanyLabel String  @default("Signed by: Eagle Info Solutions")
  signatureClientLabel String   @default("Signed by: Client")
  primaryColor         String   @default("#000000")
  secondaryColor       String   @default("#D4AF37")
  accentColor          String   @default("#D4AF37")
  backgroundColor      String   @default("#FFFFFF")
  surfaceColor         String   @default("#F5F5F5")
  borderColor          String   @default("#E5E5E5")
  updatedAt            DateTime @updatedAt
}

model InboundMessage {
  id         String   @id @default(cuid())
  wamid      String   @unique
  from       String
  body       String?
  mediaType  String?
  mediaId    String?
  mediaCaption String?
  timestamp  DateTime

  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  jobId      String?
  job        Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  isRead     Boolean  @default(false)
  readAt     DateTime?

  createdAt  DateTime @default(now())

  @@index([from, timestamp])
  @@index([jobId, timestamp])
  @@index([clientId, isRead])
  @@index([isRead, createdAt])
}

// REPAIR REQUEST FRONT_DESK MODELS
model RepairRequest {
  id            String   @id @default(cuid())
  requestNumber String   @unique
  requestStatus RepairRequestStatus @default(PENDING_FRONT_DESK)
  handoverStatus RepairHandoverStatus @default(PENDING)
  
  // Customer info
  customerName String
  phone        String
  email        String?
  preferredContactMethod ContactMethod @default(WHATSAPP)
  
  // Device info
  deviceType   DeviceType
  brand       String
  model       String?
  serialNumber String?
  
  // Problem description
  problemDescription String
  
  // Handover method specific fields
  handoverMethod    HandoverMethod
  preferredDropoffDate String?
  preferredDropoffTime String?
  dropoffNotes        String?
  
  deliveryPersonName  String?
  deliveryPersonPhone String?
  deliveryCompany     String?
  dispatchDate        String?
  expectedArrivalTime String?
  deliveryTrackingReference String?
  deliveryFeeResponsibility String?
  deliveryNotes       String?
  
  pickupAddress     String?
  pickupLandmark    String?
  preferredPickupDate String?
  preferredPickupTime String?
  alternateContactPerson String?
  alternateContactPhone String?
  pickupNotes       String?
  
  // Linked job (set when converted to a job)
  linkedJobId String?

  // Anti-spam
  submissionIp String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outboundMessages OutboundMessage[]

  @@index([requestStatus, createdAt])
  @@index([phone])
}

// Allocates human-friendly repair request numbers safely under concurrency.
model RepairRequestSequence {
  year      Int      @id
  value     Int      @default(0) // last allocated sequence value
  updatedAt DateTime @updatedAt
}

enum RepairRequestStatus {
  // Legacy: kept for existing production rows.
  PENDING_INTAKE
  PENDING_FRONT_DESK
  APPROVED
  REJECTED
  CONVERTED_TO_JOB
}

enum RepairHandoverStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ContactMethod {
  WHATSAPP
  PHONE
  EMAIL
  SMS
}

enum HandoverMethod {
  SELF_DROPOFF
  SEND_WITH_DELIVERY_PERSON
  REQUEST_PICKUP
}

// ── SALES CRM ───────────────────────────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  WON
  LOST
  STALE
}

enum LeadSource {
  WALK_IN
  REFERRAL
  PHONE
  SOCIAL_MEDIA
  WEBSITE
  OTHER
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Lead {
  id          String     @id @default(cuid())
  orgId       String?
  branchId    String?
  branch      Branch?    @relation(fields: [branchId], references: [id])
  assignedToId String?
  assignedTo  User?      @relation("LeadAssignedTo", fields: [assignedToId], references: [id])
  createdById String
  createdBy   User       @relation("LeadCreatedBy", fields: [createdById], references: [id])
  // Contact info (may become a Client)
  fullName    String
  phone       String
  email       String?
  organization String?
  clientId    String?
  client      Client?    @relation(fields: [clientId], references: [id])
  // Lead details
  status      LeadStatus @default(NEW)
  source      LeadSource @default(WALK_IN)
  notes       String?
  interest    String?    // what they're interested in
  estimatedValue Float?
  followUpAt  DateTime?
  convertedAt DateTime?
  closedAt    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  activities  LeadActivity[]
  quotations  Quotation[]

  @@index([orgId, status])
  @@index([assignedToId, status])
  @@index([branchId])
  @@index([clientId])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("LeadActivityBy", fields: [userId], references: [id])
  type      String   // CALL, NOTE, EMAIL, MEETING, STATUS_CHANGE
  note      String?
  createdAt DateTime @default(now())

  @@index([leadId])
}

model Quotation {
  id             String          @id @default(cuid())
  orgId          String?
  quoteNumber    String          @unique
  leadId         String?
  lead           Lead?           @relation(fields: [leadId], references: [id])
  clientId       String?
  client         Client?         @relation(fields: [clientId], references: [id])
  jobId          String?
  job            Job?            @relation("JobQuotation", fields: [jobId], references: [id])
  createdById    String
  createdBy      User            @relation("QuotationCreatedBy", fields: [createdById], references: [id])
  approvedById   String?
  approvedBy     User?           @relation("QuotationApprovedBy", fields: [approvedById], references: [id])
  status         QuotationStatus @default(DRAFT)
  subtotal       Float           @default(0)
  discountAmount Float           @default(0)
  vatAmount      Float           @default(0)
  totalAmount    Float           @default(0)
  validUntil     DateTime?
  notes          String?
  internalNotes  String?
  currency       String          @default("UGX")
  sentAt         DateTime?
  acceptedAt     DateTime?
  rejectedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  items          QuotationItem[]

  @@index([orgId, status])
  @@index([clientId])
  @@index([leadId])
  @@index([jobId])
}

model QuotationItem {
  id            String    @id @default(cuid())
  quotationId   String
  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  partId        String?
  part          Part?     @relation("PartQuotationItems", fields: [partId], references: [id])
  description   String
  quantity      Int       @default(1)
  unitPrice     Float
  discount      Float     @default(0)
  lineTotal     Float
  createdAt     DateTime  @default(now())

  @@index([quotationId])
}

// ── POS / SALES ─────────────────────────────────────────────────────────────

enum SaleStatus {
  OPEN
  COMPLETED
  VOIDED
  REFUNDED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIALLY_PAID
  OVERDUE
  VOIDED
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY
  BANK_TRANSFER
}

enum PosSessionStatus {
  OPEN
  CLOSED
}

model PosSession {
  id                     String           @id @default(cuid())
  orgId                  String?
  branchId               String?
  branch                 Branch?          @relation(fields: [branchId], references: [id])
  operatorId             String
  operator               User             @relation("PosSessionOperator", fields: [operatorId], references: [id])
  status                 PosSessionStatus @default(OPEN)
  openedAt               DateTime         @default(now())
  closedAt               DateTime?
  openingFloat           Float            @default(0)
  expectedClosingBalance Float?
  actualClosingBalance   Float?
  notes                  String?
  totalSales             Float            @default(0)
  totalRefunds           Float            @default(0)
  salesCount             Int              @default(0)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  sales                  Sale[]

  @@index([orgId, status])
  @@index([branchId, openedAt])
  @@index([operatorId])
}

model Sale {
  id             String      @id @default(cuid())
  orgId          String?
  branchId       String?
  branch         Branch?     @relation(fields: [branchId], references: [id])
  clientId       String?
  client         Client?     @relation(fields: [clientId], references: [id])
  posSessionId   String?
  posSession     PosSession? @relation(fields: [posSessionId], references: [id])
  createdById    String?
  createdBy      User?       @relation("SaleCreatedBy", fields: [createdById], references: [id])
  status         SaleStatus  @default(OPEN)
  saleNumber     String      @unique
  subtotal       Float       @default(0)
  discountAmount Float       @default(0)
  vatAmount      Float       @default(0)
  totalAmount    Float       @default(0)
  paidAmount     Float       @default(0)
  paidAt         DateTime?
  notes          String?
  currency       String      @default("UGX")
  billingMode    String      @default("CASH")
  invoiceNumber  String?
  invoicedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  items          SaleItem[]
  payments       Payment[]
  refunds        Refund[]

  @@index([orgId, status])
  @@index([branchId, createdAt])
  @@index([clientId])
  @@index([posSessionId])
}

model SaleItem {
  id          String   @id @default(cuid())
  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  partId      String?
  part        Part?    @relation(fields: [partId], references: [id])
  description String
  quantity    Int      @default(1)
  unitPrice   Float
  discount    Float    @default(0)
  lineTotal   Float
  createdAt   DateTime @default(now())

  @@index([saleId])
}

model Payment {
  id                 String        @id @default(cuid())
  orgId              String?
  invoiceId          String?
  invoice            Invoice?      @relation(fields: [invoiceId], references: [id])
  saleId             String?
  sale               Sale?         @relation(fields: [saleId], references: [id])
  amount             Float
  method             PaymentMethod @default(CASH)
  reference          String?
  receivedAt         DateTime      @default(now())
  createdById        String?
  createdBy          User?         @relation("PaymentCreatedBy", fields: [createdById], references: [id])
  note               String?
  currency           String        @default("UGX")
  exchangeRateToBase Float?
  createdAt          DateTime      @default(now())

  @@index([saleId])
  @@index([invoiceId])
  @@index([orgId])
}

model Invoice {
  id            String        @id @default(cuid())
  orgId         String?
  jobId         String        @unique
  job           Job           @relation(fields: [jobId], references: [id])
  invoiceNumber String        @unique
  status        InvoiceStatus @default(ISSUED)
  issuedAt      DateTime      @default(now())
  dueDate       DateTime?
  totalAmount   Float
  paidAmount    Float         @default(0)
  paidAt        DateTime?
  notes         String?
  currency      String        @default("UGX")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  payments      Payment[]
  refunds       Refund[]

  @@index([orgId, status])
  @@index([jobId])
}

model Refund {
  id           String        @id @default(cuid())
  orgId        String?
  saleId       String?
  sale         Sale?         @relation(fields: [saleId], references: [id])
  invoiceId    String?
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id])
  currency     String        @default("UGX")
  amount       Float
  method       PaymentMethod @default(CASH)
  reference    String?
  refundedAt   DateTime      @default(now())
  createdById  String
  createdBy    User          @relation("RefundCreatedBy", fields: [createdById], references: [id])
  note         String?
  createdAt    DateTime      @default(now())

  @@index([saleId])
  @@index([invoiceId])
  @@index([orgId])
}

// ── TARGETS & PRODUCTIVITY ──────────────────────────────────────────────────

enum TargetPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum TargetMetric {
  REVENUE
  JOBS_COMPLETED
  LEADS_CONVERTED
  SALES_COUNT
  CUSTOMER_SATISFACTION
  RESPONSE_TIME_HOURS
}

enum TargetEntityType {
  USER
  DEPARTMENT
  BRANCH
}

model SalesTarget {
  id           String           @id @default(cuid())
  orgId        String?
  entityType   TargetEntityType
  userId       String?
  user         User?            @relation("UserSalesTargets", fields: [userId], references: [id])
  departmentId String?
  department   Department?      @relation("DeptSalesTargets", fields: [departmentId], references: [id])
  branchId     String?
  branch       Branch?          @relation("BranchSalesTargets", fields: [branchId], references: [id])
  metric       TargetMetric
  period       TargetPeriod
  periodLabel  String           // e.g. "2026-05", "2026-Q2", "2026"
  targetValue  Float
  actualValue  Float            @default(0)
  setById      String
  setBy        User             @relation("TargetSetBy", fields: [setById], references: [id])
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([entityType, userId, departmentId, branchId, metric, period, periodLabel])
  @@index([orgId, period, periodLabel])
  @@index([userId, metric])
  @@index([departmentId, metric])
  @@index([branchId, metric])
}

// ── FIELD WORK ──────────────────────────────────────────────────────────────

enum FieldVisitType {
  COLLECTION
  DELIVERY
  ONSITE_REPAIR
  ASSESSMENT
  FOLLOWUP
}

enum FieldVisitStatus {
  SCHEDULED
  EN_ROUTE
  ARRIVED
  COMPLETED
  FAILED
  CANCELLED
}

model FieldVisit {
  id              String           @id @default(cuid())
  orgId           String?
  branchId        String?
  branch          Branch?          @relation(fields: [branchId], references: [id])
  jobId           String?
  job             Job?             @relation("JobFieldVisits", fields: [jobId], references: [id])
  assignedToId    String
  assignedTo      User             @relation("FieldVisitAssignedTo", fields: [assignedToId], references: [id])
  scheduledById   String
  scheduledBy     User             @relation("FieldVisitScheduledBy", fields: [scheduledById], references: [id])
  type            FieldVisitType
  status          FieldVisitStatus @default(SCHEDULED)
  scheduledAt     DateTime
  startedAt       DateTime?
  completedAt     DateTime?
  // Location
  address         String
  gpsLat          Float?
  gpsLng          Float?
  // Contact
  contactName     String?
  contactPhone    String?
  // Notes
  notes           String?
  outcomeNotes    String?
  signoffName     String?
  signoffAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([orgId, status])
  @@index([assignedToId, scheduledAt])
  @@index([jobId])
}
