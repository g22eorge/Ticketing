}

// ── Supplier ──────────────────────────────────────────────────────────────────

model Supplier {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  notes       String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  purchaseOrders     PurchaseOrder[]
  purchaseRequests   PurchaseRequest[]
  goodsReceivedNotes GoodsReceived[]
  supplierBills      SupplierBill[]
  expenses           Expense[]

  @@index([orgId])
}

// ── Purchase Orders ───────────────────────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED
}

enum GoodsReceivedStatus {
  POSTED
  CANCELLED
}

enum SupplierBillStatus {
  DRAFT
  POSTED
  PART_PAID
  PAID
  CANCELLED
}

enum PurchaseRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CONVERTED
  CANCELLED
}

enum PurchaseRequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum StockCountStatus {
  DRAFT
  SUBMITTED
  APPROVED
  CANCELLED
}

model PurchaseRequest {
  id            String                  @id @default(cuid())
  orgId         String
  org           Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  requestNumber String                  @unique
  status        PurchaseRequestStatus   @default(SUBMITTED)
  priority      PurchaseRequestPriority @default(NORMAL)
  supplierId    String?
  supplier      Supplier?               @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  neededBy      DateTime?
  reason        String?
  notes         String?
  requestedById String
  requestedBy   User                    @relation("PurchaseRequestCreatedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  reviewedById  String?
  reviewedBy    User?                   @relation("PurchaseRequestReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt    DateTime?
  reviewNote    String?
  convertedPoId String?
  convertedPo   PurchaseOrder?          @relation(fields: [convertedPoId], references: [id], onDelete: SetNull)
  convertedAt   DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  items         PurchaseRequestItem[]

  @@index([orgId, status, createdAt])
  @@index([supplierId])
  @@index([requestedById])
}

model PurchaseRequestItem {
  id                String          @id @default(cuid())
  requestId         String
  request           PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  partId            String?
  part              Part?           @relation(fields: [partId], references: [id], onDelete: SetNull)
  description       String
  quantity          Int
  estimatedUnitCost Float?
  createdAt         DateTime        @default(now())

  @@index([requestId])
  @@index([partId])
}

model PurchaseOrder {
  id         String              @id @default(cuid())
  orgId      String
  org        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  status     PurchaseOrderStatus @default(DRAFT)
  reference  String?
  orderedAt  DateTime?
  expectedAt DateTime?
  receivedAt DateTime?
  notes      String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  items PurchaseOrderItem[]
  purchaseRequests PurchaseRequest[]
  goodsReceivedNotes GoodsReceived[]
  supplierBills SupplierBill[]

  @@index([orgId])
  @@index([supplierId])
}

model PurchaseOrderItem {
  id          String        @id @default(cuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  partId      String?
  part        Part?         @relation(fields: [partId], references: [id])
  description String
  qtyOrdered  Int
  qtyReceived Int           @default(0)
  unitCost    Float
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([poId])
}

model GoodsReceived {
  id          String              @id @default(cuid())
  orgId       String
  org         Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  grnNumber   String              @unique
  status      GoodsReceivedStatus @default(POSTED)
  supplierId  String
  supplier    Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  poId        String?
  po          PurchaseOrder?      @relation(fields: [poId], references: [id], onDelete: SetNull)
  locationId  String
  location    StockLocation       @relation(fields: [locationId], references: [id], onDelete: Restrict)
  receivedAt  DateTime            @default(now())
  note        String?
  createdById String
  createdBy   User                @relation("GoodsReceivedCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  items       GoodsReceivedItem[]
  supplierBills SupplierBill[]

  @@index([orgId, receivedAt])
  @@index([supplierId])
  @@index([poId])
  @@index([locationId])
}

model GoodsReceivedItem {
  id          String        @id @default(cuid())
  grnId       String
  grn         GoodsReceived @relation(fields: [grnId], references: [id], onDelete: Cascade)
  poItemId    String?
  partId      String?
  part        Part?         @relation(fields: [partId], references: [id], onDelete: SetNull)
  description String
  quantity    Int
  unitCost    Float
  createdAt   DateTime      @default(now())

  @@index([grnId])
  @@index([partId])
  @@index([poItemId])
}

model SupplierBill {
  id            String             @id @default(cuid())
  orgId         String
  org           Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  billNumber    String             @unique
  supplierRef   String?
  status        SupplierBillStatus @default(POSTED)
  supplierId    String
  supplier      Supplier           @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  poId          String?
  po            PurchaseOrder?     @relation(fields: [poId], references: [id], onDelete: SetNull)
  grnId         String?
  grn           GoodsReceived?     @relation(fields: [grnId], references: [id], onDelete: SetNull)
  currency      String             @default("UGX")
  subtotal      Float
  taxAmount     Float              @default(0)
  totalAmount   Float
  paidAmount    Float              @default(0)
  issuedAt      DateTime           @default(now())
  dueAt         DateTime?
  notes         String?
  createdById   String
  createdBy     User               @relation("SupplierBillCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  items         SupplierBillItem[]
  payments      SupplierPayment[]

  @@index([orgId, issuedAt])
  @@index([orgId, status])
  @@index([supplierId])
  @@index([poId])
  @@index([grnId])
}

model SupplierBillItem {
  id          String       @id @default(cuid())
  billId      String
  bill        SupplierBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unitCost    Float
  lineTotal   Float
  createdAt   DateTime     @default(now())

  @@index([billId])
}

model SupplierPayment {
  id          String        @id @default(cuid())
  orgId       String
  org         Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  billId      String
  bill        SupplierBill  @relation(fields: [billId], references: [id], onDelete: Cascade)
  currency    String        @default("UGX")
  amount      Float
  method      PaymentMethod @default(CASH)
  reference   String?
  paidAt      DateTime      @default(now())
  note        String?
  createdById String
  createdBy   User          @relation("SupplierPaymentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime      @default(now())

  @@index([orgId, paidAt])
  @@index([billId])
}

model StockCount {
  id           String           @id @default(cuid())
  orgId        String
  org          Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  countNumber  String           @unique
  status       StockCountStatus @default(DRAFT)
  locationId   String
  location     StockLocation    @relation(fields: [locationId], references: [id], onDelete: Restrict)
  countedAt    DateTime         @default(now())
  submittedAt  DateTime?
  approvedAt   DateTime?
  note         String?
  createdById  String
  createdBy    User             @relation("StockCountCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  approvedById String?
  approvedBy   User?            @relation("StockCountApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  items        StockCountItem[]

  @@index([orgId, status, countedAt])
  @@index([locationId])
}

model StockCountItem {
  id           String     @id @default(cuid())
  stockCountId String
  stockCount   StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  partId       String
  part         Part       @relation(fields: [partId], references: [id], onDelete: Restrict)
  systemQty    Int
  countedQty   Int
  varianceQty  Int
  note         String?
  createdAt    DateTime   @default(now())

  @@index([stockCountId])
  @@index([partId])
}

model SystemAuditEvent {
  id          String   @id @default(cuid())
  orgId       String?
  actorUserId String?
  entityType  String
  entityId    String
  action      String
  summary     String?
  beforeJson  String?
  afterJson   String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
}

model OrgFeatureEntitlement {
  id           String    @id @default(cuid())
  orgId        String
  feature      String
  enabled      Boolean   @default(true)
  limitValue   Float?
  metadataJson String?
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([orgId, feature])
  @@index([orgId, enabled])
}

model OrgSubscriptionEvent {
  id              String   @id @default(cuid())
  orgId           String
  provider        String
  eventType       String
  providerEventId String?
  plan            String?
  status          String?
  amount          Float?
  currency        String?
  payloadJson     String?
  occurredAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([orgId, occurredAt])
  @@index([provider, providerEventId])
}

model OrgUsageSnapshot {
  id           String   @id @default(cuid())
  orgId        String
  periodKey    String
  metric       String
  value        Float
  capturedAt   DateTime @default(now())
  metadataJson String?

  @@unique([orgId, periodKey, metric])
  @@index([orgId, metric, capturedAt])
}

model OrgSecurityPolicy {
  id                    String   @id @default(cuid())
  orgId                 String   @unique
  requireMfa            Boolean  @default(false)
  sessionTimeoutMinutes Int?
  passwordMinLength     Int      @default(8)
  allowedIpRanges       String?
  updatedById           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model BranchOperatingHours {
  id        String   @id @default(cuid())
  branchId  String
  dayOfWeek Int
  opensAt   String?
  closesAt  String?
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, dayOfWeek])
  @@index([branchId])
}

model BranchNumberingSettings {
  id               String   @id @default(cuid())
  branchId         String   @unique
  jobPrefix        String?
  invoicePrefix    String?
  receiptPrefix    String?
  quotationPrefix  String?
  salePrefix       String?
  nextJobSequence  Int      @default(1)
  nextSaleSequence Int      @default(1)
  updatedAt        DateTime @updatedAt
}

model CustomerConsent {
  id          String    @id @default(cuid())
  orgId       String
  clientId    String
  consentType String
  channel     String?
  granted     Boolean   @default(true)
  source      String?
  capturedAt  DateTime  @default(now())
  expiresAt   DateTime?
  note        String?

  @@index([orgId, clientId, consentType])
  @@index([orgId, capturedAt])
}

model ClientMergeRecord {
  id             String   @id @default(cuid())
  orgId          String
  sourceClientId String
  targetClientId String
  mergedById     String
  reason         String?
  snapshotJson   String?
  mergedAt       DateTime @default(now())

  @@index([orgId, mergedAt])
  @@index([sourceClientId])
  @@index([targetClientId])
}

model DeviceSpecification {
  id        String   @id @default(cuid())
  orgId     String
  deviceId  String
  key       String
  value     String
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([deviceId, key])
  @@index([orgId, key])
}

model JobAssignmentHistory {
  id             String    @id @default(cuid())
  orgId          String
  jobId          String
  assignedToId   String?
  assignedById   String?
  assignmentType String    @default("PRIMARY")
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  note           String?

  @@index([orgId, jobId, startedAt])
  @@index([assignedToId, startedAt])
}

model JobStatusHistory {
  id           String   @id @default(cuid())
  orgId        String
  jobId        String
  fromStatus   String?
  toStatus     String
  reason       String?
  changedById  String?
  changedAt    DateTime @default(now())
  metadataJson String?

  @@index([orgId, jobId, changedAt])
  @@index([orgId, toStatus, changedAt])
}

model DiagnosisReport {
  id              String   @id @default(cuid())
  orgId           String
  jobId           String
  authorId        String?
  visibility      String   @default("INTERNAL")
  summary         String
  findings        String?
  recommendedWork String?
  riskNotes       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orgId, jobId, createdAt])
}

model RepairTask {
  id           String    @id @default(cuid())
  orgId        String
  jobId        String
  title        String
  description  String?
  status       String    @default("PENDING")
  priority     String    @default("NORMAL")
  assignedToId String?
  dueAt        DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([orgId, jobId, status])
  @@index([assignedToId, status, dueAt])
}

model CustomerApproval {
  id              String    @id @default(cuid())
  orgId           String
  jobId           String
  approvalType    String
  status          String    @default("PENDING")
  amount          Float?
  currency        String?
  requestedById   String?
  respondedByName String?
  responseNote    String?
  requestedAt     DateTime  @default(now())
  respondedAt     DateTime?

  @@index([orgId, jobId, status])
  @@index([orgId, requestedAt])
}

model QualityCheck {
  id            String    @id @default(cuid())
  orgId         String
  jobId         String
  checkedById   String?
  status        String    @default("PENDING")
  checklistJson String?
  notes         String?
  checkedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([orgId, jobId, status])
}

model WarrantyClaim {
  id            String    @id @default(cuid())
  orgId         String
  originalJobId String
  warrantyJobId String?
  status        String    @default("OPEN")
  reason        String
  resolution    String?
  openedAt      DateTime  @default(now())
  closedAt      DateTime?

  @@index([orgId, status, openedAt])
  @@index([originalJobId])
}

model InventoryCategory {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  parentId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, name])
  @@index([orgId, isActive])
}

model StockLocation {
  id        String   @id @default(cuid())
  orgId     String
  branchId  String?
  name      String
  code      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goodsReceivedNotes GoodsReceived[]
  stockCounts StockCount[]

  @@unique([orgId, code])
  @@index([orgId, branchId, isActive])
}

model PartLocationStock {
  id          String   @id @default(cuid())
  orgId       String
  partId      String
  locationId  String
  qtyOnHand   Int      @default(0)
  qtyReserved Int      @default(0)
  updatedAt   DateTime @updatedAt

  part Part @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([partId, locationId])
  @@index([orgId, locationId])
  @@index([partId])
}

model StockTransfer {
  id             String              @id @default(cuid())
  orgId          String
  org            Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  transferNumber String              @unique
  status         StockTransferStatus @default(REQUESTED)
  fromLocationId String
  toLocationId   String
  requestedAt    DateTime            @default(now())
  approvedAt     DateTime?
  dispatchedAt   DateTime?
  receivedAt     DateTime?
  cancelledAt    DateTime?
  note           String?

  createdById    String
  createdBy      User                @relation("StockTransferCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  approvedById   String?
  approvedBy     User?               @relation("StockTransferApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  dispatchedById String?
  dispatchedBy   User?               @relation("StockTransferDispatchedBy", fields: [dispatchedById], references: [id], onDelete: SetNull)
  receivedById   String?
  receivedBy     User?               @relation("StockTransferReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)

  items          StockTransferItem[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([orgId, status, createdAt])
  @@index([fromLocationId])
  @@index([toLocationId])
}

model StockTransferItem {
  id             String        @id @default(cuid())
  transferId     String
  transfer       StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  partId         String
  part           Part          @relation(fields: [partId], references: [id], onDelete: Restrict)
  quantity       Int
  qtyDispatched  Int           @default(0)
  qtyReceived    Int           @default(0)
  note           String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([transferId])
  @@index([partId])
}

model SupplierPrice {
  id           String    @id @default(cuid())
  orgId        String
  supplierId   String
  partId       String?
  sku          String?
  description  String
  unitCost     Float
  currency     String    @default("UGX")
  minQuantity  Int?
  leadTimeDays Int?
  validFrom    DateTime  @default(now())
  validTo      DateTime?
  createdAt    DateTime  @default(now())

  @@index([orgId, supplierId, validFrom])
  @@index([partId, validFrom])
}

model ReorderRule {
  id                  String   @id @default(cuid())
  orgId               String
  partId              String
  locationId          String?
  minQty              Int      @default(0)
  targetQty           Int      @default(0)
  preferredSupplierId String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([partId, locationId])
  @@index([orgId, isActive])
}

model InvoiceLine {
  id             String   @id @default(cuid())
  orgId          String
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sourceType     String?
  sourceId       String?
  description    String
  quantity       Float    @default(1)
  unitPrice      Float
  discountAmount Float    @default(0)
  taxAmount      Float    @default(0)
  lineTotal      Float
  createdAt      DateTime @default(now())

  @@index([orgId, invoiceId])
  @@index([sourceType, sourceId])
}

model TaxRate {
  id                 String       @id @default(cuid())
  orgId              String
  org                Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name               String
  code               String
  rate               Float
  isDefault          Boolean      @default(false)
  isActive           Boolean      @default(true)
  appliesToSales     Boolean      @default(true)
  appliesToPurchases Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([orgId, code])
  @@index([orgId])
}

model Expense {
  id                 String          @id @default(cuid())
  orgId              String
  org                Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  expenseNumber      String          @unique
  category           ExpenseCategory @default(OTHER)
  description        String
  amount             Float
  currency           String          @default("UGX")
  exchangeRateToBase Float?
  paidAt             DateTime?
  method             PaymentMethod?
  supplierId         String?
  supplier           Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  branchId           String?
  branch             Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  reference          String?
  notes              String?
  createdById        String
  createdBy          User            @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt          DateTime        @default(now())

  @@index([orgId, paidAt])
  @@index([orgId, category])
  @@index([supplierId])
}

model RecurringInvoice {
