# ─────────────────────────────────────────────
# MRMS — Environment Variables Reference
# Copy this file to .env.local and fill in values.
# Never commit .env.local or any file containing real secrets.
# ─────────────────────────────────────────────

# ── App URLs ──────────────────────────────────
# Public URL of the deployed application (no trailing slash)
APP_URL=https://your-app.example.com
NEXT_PUBLIC_APP_URL=https://your-app.example.com
NEXT_PUBLIC_SITE_URL=https://your-app.example.com

# ── Authentication (BetterAuth) ───────────────
# Must match APP_URL in production
AUTH_URL=https://your-app.example.com
BETTER_AUTH_URL=https://your-app.example.com
# Comma-separated list of trusted origins (usually same as APP_URL)
BETTER_AUTH_TRUSTED_ORIGINS=https://your-app.example.com
# Secret used to sign sessions — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=change_me_use_openssl_rand_hex_32

# ── Database ──────────────────────────────────
# SQLite (development / single-server production)
DATABASE_URL=file:./dev.db
# Set to "true" only if you intentionally run SQLite in production
# Not recommended for multi-server deployments
ALLOW_SQLITE_PRODUCTION=false

# Turso (recommended for production — LibSQL-compatible SQLite)
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your_turso_auth_token

# ── File Storage ──────────────────────────────
# Absolute path to the uploads directory on disk
UPLOADS_DIR=/var/data/mrms/uploads
# Optional: separate directory for generated PDF files (defaults to public/uploads/pdfs)
# PDF_UPLOAD_DIR=/var/data/mrms/pdfs
# Optional: public URL to serve uploaded files (leave blank to use built-in handler)
# UPLOADS_BASE_URL=https://cdn.example.com/uploads

# ── Redis (optional) ──────────────────────────
# Redis connection URL for background job queue and permission cache
# Leave blank to run in single-process in-memory mode (no persistence, fine for single-server)
# REDIS_URL=redis://localhost:6379

# ── Platform Administration ───────────────────
# Email address that receives full platform-admin access
PLATFORM_ADMIN_EMAIL=admin@example.com

# ── CORS / Allowed Origins ────────────────────
# Additional allowed origins for API requests (comma-separated if needed)
# ALLOWED_ORIGIN_1=https://another-domain.example.com

# ── Email (Resend) ────────────────────────────
# From address for transactional emails (must be a verified Resend sender)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=noreply@example.com
EMAIL_FROM=noreply@example.com
# Address for internal alert emails (e.g. new repair requests)
RESEND_ALERTS_FROM=alerts@example.com
REPAIR_REQUEST_ALERT_EMAIL=ops@example.com

# ── WhatsApp (Meta Cloud API) ─────────────────
# Provider — currently only "meta" is supported
WHATSAPP_PROVIDER=meta
# Permanent system user token from Meta Business Manager
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
# Business Account ID from Meta Business Manager
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
# Phone number in E.164 format shown to customers (e.g. +256700000000)
WHATSAPP_BUSINESS_NUMBER=+256700000000
# Phone Number ID from Meta Business Manager
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# Random string used to verify the webhook subscription with Meta
WHATSAPP_WEBHOOK_VERIFY_TOKEN=random_string_you_choose
# App Secret from Meta App Dashboard — used to validate incoming webhook signatures
WHATSAPP_WEBHOOK_APP_SECRET=your_meta_app_secret
# Public-facing WhatsApp number displayed in the UI (optional)
NEXT_PUBLIC_WHATSAPP_NUMBER=+256700000000

# ── SMS (Africa's Talking) ────────────────────
# Platform-level AT account — all organisations share this quota
AT_USERNAME=your_africastalking_username
AT_API_KEY=your_africastalking_api_key
# Default sender name (alphanumeric, max 11 chars, must be approved by AT)
AT_SENDER_ID=EagleInfo

# ── Payment Gateway (Pesapal) ─────────────────
PESAPAL_CONSUMER_KEY=your_pesapal_consumer_key
PESAPAL_CONSUMER_SECRET=your_pesapal_consumer_secret
# "sandbox" for testing, "live" for production
PESAPAL_ENV=sandbox

# ── AI (Google Gemini) ──────────────────────────
# API key for AI Guide and Business Copilot features
GEMINI_API_KEY=your_gemini_api_key
# Optional: override the default Gemini model (defaults to gemini-1.5-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ── Cron Jobs ─────────────────────────────────
# Secret token that must be present in the Authorization header for cron requests
# Generate with: openssl rand -hex 32
CRON_SECRET=change_me_use_openssl_rand_hex_32

# ── Message Retry ─────────────────────────────
# Maximum number of delivery attempts for outbound WhatsApp/SMS messages (default: 5)
OUTBOX_RETRY_LIMIT=5

# ── Branding & Company Info ───────────────────
# Used on public-facing pages (status tracker, invoices, etc.)
NEXT_PUBLIC_COMPANY_ADDRESS=123 Main Street, Kampala, Uganda
NEXT_PUBLIC_COMPANY_SITE_URL=https://www.example.com
NEXT_PUBLIC_CONTACT_EMAIL=support@example.com
# Optional: URL to a logo image for generated invoice PDFs
INVOICE_LOGO_URL=https://www.example.com/logo.png

# ── Currency ──────────────────────────────────
# ISO 4217 currency code used as the system default (e.g. UGX, KES, USD)
APP_CURRENCY=UGX

# ── Default Org (Development/Testing Only) ────
# Pre-set the default org ID for local dev without full onboarding
# Remove or leave blank in production
DEFAULT_ORG_ID=

# ── Node Environment ──────────────────────────
NODE_ENV=production
